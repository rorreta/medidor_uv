<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UV Valparaíso | Monitor Oficial</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white shadow-2xl rounded-[2.5rem] p-8 max-w-sm w-full border border-gray-100 text-center">
        <header class="mb-6">
            <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">
                En Vivo • Región de Valparaíso
            </span>
        </header>

        <section id="loader" class="py-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
        </section>

        <section id="content" class="hidden">
            <h1 class="text-gray-400 text-sm font-medium">Índice UV Máximo Hoy</h1>
            <div id="uv-number" class="text-9xl font-black my-4 tracking-tighter transition-all duration-700">
                0
            </div>
            
            <div id="uv-badge" class="inline-block px-4 py-2 rounded-2xl font-bold text-white mb-6">
                Cargando...
            </div>

            <div class="grid grid-cols-2 gap-4 text-left border-t border-gray-100 pt-6">
                <div>
                    <p class="text-gray-400 text-xs uppercase">Latitud</p>
                    <p class="font-bold text-gray-700">-33.04</p>
                </div>
                <div>
                    <p class="text-gray-400 text-xs uppercase">Longitud</p>
                    <p class="font-bold text-gray-700">-71.61</p>
                </div>
            </div>
        </section>

        <footer class="mt-8">
            <p class="text-gray-300 text-[10px] leading-tight">
                Datos provistos por Open-Meteo OMS.<br>Actualizado automáticamente cada 24h.
            </p>
        </footer>
    </div>

    <script>
        const UI = {
            number: document.getElementById('uv-number'),
            badge: document.getElementById('uv-badge'),
            content: document.getElementById('content'),
            loader: document.getElementById('loader')
        };

        async function fetchUVData() {
            // Coordenadas exactas de Valparaíso
            const lat = -33.0472;
            const lon = -71.6127;
            const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=uv_index_max&timezone=auto`;

            try {
                const response = await fetch(url);
                const data = await response.json();
                const uvIndex = data.daily.uv_index_max[0];
                
                updateDisplay(uvIndex);
            } catch (error) {
                console.error("Error obteniendo datos:", error);
                UI.badge.innerText = "Error de conexión";
                UI.badge.classList.add('bg-red-500');
            }
        }

        function updateDisplay(val) {
            UI.number.innerText = val.toFixed(1);
            UI.loader.classList.add('hidden');
            UI.content.classList.remove('hidden');

            // Escala de Riesgo OMS
            let config = { label: 'Extremo', color: 'text-purple-600', bg: 'bg-purple-600' };

            if (val <= 2) {
                config = { label: 'Bajo', color: 'text-green-500', bg: 'bg-green-500' };
            } else if (val <= 5) {
                config = { label: 'Moderado', color: 'text-yellow-500', bg: 'bg-yellow-500' };
            } else if (val <= 7) {
                config = { label: 'Alto', color: 'text-orange-500', bg: 'bg-orange-500' };
            } else if (val <= 10) {
                config = { label: 'Muy Alto', color: 'text-red-600', bg: 'bg-red-600' };
            }

            UI.number.className = `text-9xl font-black my-4 tracking-tighter transition-all duration-700 ${config.color}`;
            UI.badge.className = `inline-block px-4 py-2 rounded-2xl font-bold text-white mb-6 ${config.bg}`;
            UI.badge.innerText = config.label;
        }

        fetchUVData();
    </script>
</body>
</html>
